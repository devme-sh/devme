(( $+functions[_devme_commands] )) ||
_devme_commands() {
    local commands; commands=(
'up:Start the supervisor (or attach to a running one) and bring services up' \
'down:Shut down this instance'\''s supervisor' \
'status:Print a snapshot of current service status' \
'restart:Restart a service' \
'stop:Stop a single service (keep the daemon running)' \
'start:Start a single service' \
'logs:Tail logs for a service' \
'completions:Print a shell completion script. Pipe into your shell'\''s completion directory\: \`devme completions fish > ~/.config/fish/completions/devme.fish\`' \
'doctor:Diagnostic snapshot\: service states + recent error logs. Designed for agents — outputs structured JSON with everything needed to diagnose failures without multiple round-trips' \
'config:View or change devme global settings' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'devme commands' commands "$@"
}
